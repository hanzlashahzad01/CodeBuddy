//foreign key jo hoti ha wo 2 tables ko link karti ha apas mia...foreign key in one table used to point primary key in another table...

//method...

create table file(
id int not null unique,
name varchar(50) not null,
gender varchar(1) not null,
phone varchar(12) not null unique,
age int not null check(age>=18),
city varchar(15) not null default 'Lahore',
percentage int not null,
primary key (id),
foreign key (city) references city (city_id)

);

//ab jo city wala table tha us ki id ko primary kkey set kia ha or ye file wlay table ki id ko bhi primary set kia ha or is kky city ko foreign

//key set kia ha is sey ab kia ho ga jo ye file wala table ha is mia jo cities hain ye ab city ka name show nai karwy ga un ki id dy ga...


//agr kio table phley sey create ha to ye method ho ga....

//method...

alter table table_name
add foreign key (city) references city(id);
