create view view_name

as

//as ky baad wo sara data jo ap na view mia store karna ho ga....


CREATE VIEW studentdata
AS
SELECT id,name,city from
personal p  inner join city c
on p.city = c.cityname;


SELECT * from studentdata;

//ab ye view ko studentdata ky name sey mia na create kiya ha phr as ka use ky phr sara data entry karna wo ap ko chahiye ho ga baad mia....

//phr SELECT * from studentdata kr ky ap data ko view bhi kr sekhty hain.....



ALTER VIEW studentdata
AS
SELECT id,name,cityname from
personal p  inner join city c
on p.city = c.cityname;


SELECT * from studentdata;


// jo data view mia phley sey store tha agr us mia ap ko baad mia changing karni ha to ap ko alter view ka use karna ho ga.....

//phr ap existing table mia changing bhi kr sekhty hain....




create or replace VIEW studentdata
AS
SELECT id,name,cityname from
personal p  inner join city c
on p.city = c.cityname;


SELECT * from studentdata;



//ye alter ki tarha hi kam karti ha bus syntx ka diff ha alter use kr lo ya 2 hi same hain....




RENAME TABLE studentdata

to studentcourse;


SELECT * from studentcourse;


//ap is sey view ka name bhi replace kr skehty hain baad mia.....





drop view studentcourse;

SELECT * from studentcourse;



